__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# Flask session files (local dev)
backend/flask_session/

# SQLite database (local dev)
backend/recommendation.db

# Node / frontend build output
frontend/node_modules/
frontend/dist/

# macOS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.py
*.pth
/backend
