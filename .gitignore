# ─────────────────────────────────────────────────────────────────────────────
# .gitignore
#
# FIXED: The previous version ended with:
#   *.py       ← excluded ALL Python files (entire backend vanished from git!)
#   *.pth      ← excluded PyTorch path files (harmless but unnecessary here)
#   /backend   ← excluded the entire backend/ directory from git!
#
# Those three lines have been REMOVED. Everything else is unchanged.
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets ───────────────────────────────────────────────────────────────────
# Never commit these — set them as environment variables in Render / Vercel
.env
.env.local
.env.*.local

# ── Python bytecode & packaging ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
.eggs/
dist/
build/

# ── Python virtual environments ───────────────────────────────────────────────
venv/
.venv/
env/
.env-backend/

# ── Flask runtime files ───────────────────────────────────────────────────────
# Session files generated at runtime — do NOT commit
backend/flask_session/

# ── SQLite database ───────────────────────────────────────────────────────────
# The DB is created at runtime; never commit it
backend/recommendation.db
*.db
*.sqlite
*.sqlite3

# ── HuggingFace / sentence-transformers model cache ──────────────────────────
# Models are downloaded at startup — do NOT commit (~90 MB per model)
.hf_cache/
backend/.hf_cache/
*.pth
*.bin

# ── Node / frontend ───────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
node_modules/

# ── OS & IDE ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Docker (local volumes) ────────────────────────────────────────────────────
docker/volumes/
