# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env for local development:
#   cp .env.example .env
#
# For deployment, set these in the Render dashboard (backend) and
# Vercel dashboard (frontend) — never commit real secrets to git.
# ─────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════
# BACKEND  (set these in Render → Environment Variables)
# ═══════════════════════════════════════════════════════════════════════

# Flask secret key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=mueen-dev-secret-key-please-change-me-in-production

# Comma-separated list of origins allowed to call the API.
#
# LOCAL DEV:    http://localhost:3000,http://localhost:5173
# DOCKER:       http://localhost,http://localhost:80
# PRODUCTION:   https://your-app.vercel.app
#
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# SQLite database path.
# LOCAL DEV:    leave blank → defaults to backend/recommendation.db
# RENDER FREE:  /tmp/mueen.db  (⚠️ EPHEMERAL — data lost on restart)
# RENDER PAID:  /mnt/data/mueen.db  (persistent disk mounted at /mnt/data)
DB_PATH=

# Flask-Session storage directory.
# LOCAL DEV:    leave blank → defaults to backend/flask_session/
# RENDER FREE:  /tmp/mueen_sessions  (⚠️ EPHEMERAL)
# RENDER PAID:  /mnt/data/flask_session
SESSION_DIR=

# HuggingFace model cache (sentence-transformers downloads here)
# LOCAL DEV:    leave blank → uses ~/.cache/huggingface
# RENDER:       /tmp/hf_cache  (re-downloaded on each cold start)
HF_HOME=
TRANSFORMERS_CACHE=

# HuggingFace API token — only needed for the AI summary feature.
# Get one at: https://huggingface.co/settings/tokens
HF_TOKEN=

# ═══════════════════════════════════════════════════════════════════════
# FRONTEND  (set these in Vercel → Settings → Environment Variables)
# ═══════════════════════════════════════════════════════════════════════

# The full URL of your Render backend (NO trailing slash, NO /api).
#
# LOCAL DEV:   leave blank → Vite proxy handles /api → http://localhost:5000
# PRODUCTION:  https://mueen-backend.onrender.com
#
VITE_API_URL=

# ═══════════════════════════════════════════════════════════════════════
# DOCKER  (used by docker-compose.yml only)
# ═══════════════════════════════════════════════════════════════════════
PORT=80
