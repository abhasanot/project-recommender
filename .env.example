# ─────────────────────────────────────────────────────────────────────────────
# .env.example
#
# Copy this file to .env and adjust values before running Docker.
#
#   cp .env.example .env
#   docker compose up --build
#
# docker-compose.yml automatically loads .env from the same directory.
# ─────────────────────────────────────────────────────────────────────────────

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED in production: replace with a long random string.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=mueen-dev-secret-key-please-change-me-in-production

# ── Network ───────────────────────────────────────────────────────────────────
# External port that nginx listens on. Change to e.g. 8080 if port 80 is taken.
PORT=80

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of browser origins allowed to call the API.
# When using the default nginx setup, the browser origin is http://localhost.
# Add your domain here if deploying to a server, e.g. https://myapp.example.com
CORS_ORIGINS=http://localhost,http://localhost:80,http://127.0.0.1,http://127.0.0.1:80
